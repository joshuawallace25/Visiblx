{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/client/layout,_N_T_/client/[subdomain]/layout,_N_T_/client/[subdomain]/page,_N_T_/client/rachel"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/client/$d$subdomain/__PAGE__",
    "/client/$d$subdomain",
    "/client",
    "/_index",
    "/_head"
  ]
}