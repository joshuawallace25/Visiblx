              "secondary-container": "#1c166d",
              "inverse-primary": "#842cd3",
              "tertiary-fixed": "#ff99ca",
              "surface-container-high": "#101e3e",
              "primary-fixed-dim": "#d09eff",
              "on-surface-variant": "#9baad6",
              "secondary-fixed-dim": "#d2d0ff",
              "on-primary-container": "#000000",
              "outline": "#65759e",
              "on-tertiary-fixed": "#46002c",
              "on-secondary-fixed": "#373487",
              "outline-variant": "#38476d",
              "on-primary-fixed-variant": "#6700b0",
              "on-primary-fixed": "#3d006c",
              "error-dim": "#c8475d",
              "secondary-fixed": "#e2dfff",
              "secondary-dim": "#a19ff9",
              "primary-container": "#af5cfe",
              "on-tertiary-container": "#6e0048",
              "tertiary-fixed-dim": "#ff81c1",
              "on-tertiary-fixed-variant": "#7b0852",
              "on-tertiary": "#7c0953",
              "tertiary": "#ffafd3",
              "primary-dim": "#9c48ea",
              "surface-container": "#0c1934",
              "tertiary-container": "#ff99ca",
              "on-secondary-fixed-variant": "#5352a5",
              "on-primary": "#33005b",
              "surface-dim": "#060e20",
              "surface-container-lowest": "#000000",
              "primary": "#c180ff",
              "surface-container-highest": "#142449",
              "background": "#060e20",
              "surface-tint": "#c180ff"
            },
            fontFamily: {
              "headline": ["Plus Jakarta Sans"],
              "body": ["Plus Jakarta Sans"],
              "label": ["Inter"]
            },
            borderRadius: {"DEFAULT": "1rem", "lg": "2rem", "xl": "3rem", "full": "9999px"},
            animation: {
              'pulse-slow': 'pulse 6s cubic-bezier(0.4, 0, 0.6, 1) infinite',
              'float': 'float 6s ease-in-out infinite',
              'typing': 'typing 3.5s steps(40, end), blink-caret .75s step-end infinite',
            },
            keyframes: {
              float: {
                '0%, 100%': { transform: 'translateY(0)' },
                '50%': { transform: 'translateY(-20px)' },
              },
              typing: {
                from: { width: '0' },
                to: { width: '100%' }
              },
              'blink-caret': {
                'from, to': { borderColor: 'transparent' },
                '50%': { borderColor: '#c180ff' }
              }
            }
          },
        },
      }
