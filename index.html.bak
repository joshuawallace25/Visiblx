<!-- Footer -->
<footer class="w-full rounded-t-[4rem] mt-20 bg-surface-container-lowest border-t border-outline-variant/10">
<div class="flex flex-col md:flex-row justify-between items-center px-12 py-20 gap-12 max-w-[1440px] mx-auto">
<div class="flex flex-col items-center md:items-start gap-6">
<div class="text-3xl font-black text-[#dee5ff] tracking-tighter">Visiblx</div>
<p class="font-['Inter'] text-sm tracking-widest uppercase text-[#38476d]">© 2024 Visiblx. Powered by the Digital Aurora.</p>
</div>
<div class="flex flex-wrap justify-center gap-10 font-['Inter'] text-xs tracking-widest uppercase font-bold">
