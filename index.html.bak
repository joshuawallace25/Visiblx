<style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .glass { background: rgba(20, 36, 73, 0.4); backdrop-filter: blur(20px); border: 1px solid rgba(193, 128, 255, 0.1); }
        .glass-high { background: rgba(24, 43, 89, 0.6); backdrop-filter: blur(25px); border: 1px solid rgba(193, 128, 255, 0.2); }
        .mesh-glow { background: radial-gradient(circle at 50% 50%, rgba(193, 128, 255, 0.1) 0%, transparent 70%); }
        .aurora-bg { background: linear-gradient(135deg, #060e20 0%, #142449 50%, #060e20 100%); position: relative; overflow: hidden; }
        .aurora-bg::before { content: ''; position: absolute; top: -50%; left: -50%; width: 200%; height: 200%; background: radial-gradient(circle at center, rgba(193, 128, 255, 0.05) 0%, transparent 50%); animation: rotate 20s linear infinite; }
        @keyframes rotate { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
        .text-glow { text-shadow: 0 0 20px rgba(193, 128, 255, 0.5); }
        .google-blue { color: #4285F4; }
        .google-red { color: #EA4335; }
        .google-yellow { color: #FBBC05; }
        .google-green { color: #34A853; }
        .reveal { opacity: 0; transform: translateY(30px); transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1); }
        .reveal.active { opacity: 1; transform: translateY(0); }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        .typing-cursor::after { content: '|'; animation: blink-caret 0.75s step-end infinite; color: #c180ff; }
    </style>
</head>
